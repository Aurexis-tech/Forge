# dependencies
node_modules
.pnp
.pnp.js

# next — root-anchored so they don't match application directories
# named build/ (e.g. app/api/projects/[id]/build/, components/build/).
.next
/out
/build
/dist

# terraform — defence in depth. The engine NEVER writes state to the
# repo (it's encrypted in supabase via lib/crypto), but if a local
# `terraform` ever lands a state file in the tree, never let it
# accidentally end up in version control.
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# env
.env
.env*.local
.env.local
.env.development.local
.env.production.local

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# editor
.vscode
.idea
.DS_Store

# typescript
*.tsbuildinfo
next-env.d.ts.bak

# Claude Code — local-only settings (per-user permission allowlist).
# `.claude/settings.json` (without .local) is fine to commit if a shared
# team config is added later; this rule only excludes the local override.
.claude/settings.local.json
