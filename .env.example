# Supabase project URL (safe to expose; used by browser & server)
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose; RLS enforces access)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Never commit, never expose to the browser.
# Used by API route handlers / server actions for privileged writes.
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (server-only) ---
# Used by the spec extractor and later engine phases.
ANTHROPIC_API_KEY=
# Override to swap models without touching code. Defaults to claude-sonnet-4-6
# (a strong reasoning model well-suited to the spec extraction task).
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: use a different model for the planner. Planning benefits from a
# stronger reasoner; leave unset to use ANTHROPIC_MODEL.
ANTHROPIC_PLANNER_MODEL=

# Optional: use a different model for codegen. Code generation benefits from a
# strong coding model; leave unset to fall back to ANTHROPIC_PLANNER_MODEL.
ANTHROPIC_CODEGEN_MODEL=

# --- Sandbox (server-only) ---
# Which sandbox provider to use. Currently supported: 'e2b' (default).
# 'local-docker' is a clearly stubbed placeholder for later self-hosting.
SANDBOX_PROVIDER=e2b

# E2B is built for executing untrusted AI-generated code. Provision a key at
# https://e2b.dev/ and paste it here. NEVER pass this key into generated code.
E2B_API_KEY=

# --- App ---
# Where the Forge is served. Used to construct OAuth redirect URIs. In
# development this is usually http://localhost:3000.
APP_BASE_URL=http://localhost:3000

# Base64-encoded 32-byte key for AES-256-GCM encryption of stored tokens.
# Generate with: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
# Never commit a real key. Rotating this key invalidates all stored connections.
APP_ENC_KEY=

# --- GitHub integration (server-only) ---
# Create an OAuth App at https://github.com/settings/developers with the
# callback URL: ${APP_BASE_URL}/api/connections/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# --- Vercel integration (server-only) ---
# OAuth-integration credentials (preferred). Create a Vercel integration at
# https://vercel.com/dashboard/integrations and set the redirect URL to:
#   ${APP_BASE_URL}/api/connections/vercel/callback
# VERCEL_INTEGRATION_SLUG is the slug shown in the integration's install URL.
# If these are blank the UI falls back to a Personal Access Token paste flow.
VERCEL_OAUTH_CLIENT_ID=
VERCEL_OAUTH_CLIENT_SECRET=
VERCEL_INTEGRATION_SLUG=

# --- Runtime (always_on / scheduled agents) ---
# Shared secret for the cron tick endpoint. Vercel Cron Jobs automatically
# attach Authorization: Bearer ${CRON_SECRET} when this is set. Generate
# any high-entropy string. Required for /api/runtime/tick to accept calls.
CRON_SECRET=

# --- BYOK (Bring-Your-Own-Key) ---
# When true (DEFAULT), users with no connected key get a friendly
# "connect your Anthropic key" prompt instead of silently spending the
# Forge's platform key. Flip to false ONLY after you've intentionally
# enabled the platform-billing path.
REQUIRE_BYOK=true
